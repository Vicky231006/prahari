# ─── PRAHARI Environment Configuration ───
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.

# ── Infrastructure ──
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
REDIS_HOST=redis
REDIS_PORT=6379
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=prahari
POSTGRES_USER=prahari
POSTGRES_PASSWORD=changeme
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ── Gemini API (RAG Explanation Service, Section 7) ──
GEMINI_API_KEY=your-gemini-api-key-here

# ── Application ──
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080
FUSION_CLASSIFIER_URL=http://fusion-classifier:8081
RAG_SERVICE_URL=http://rag-explanation:8082

# ── Security ──
JWT_SECRET=changeme-generate-a-real-secret

# ── Demo Mode (Section 9 — Scenario Runner) ──
# Set to true ONLY for demo/testing. Enables the Scenario Runner panel.
# Must be false in any production-like deployment.
DEMO_MODE=true

